{
  "name": "toolbox-server",
  "version": "1.0.0",
  "description": "Image optimization and format conversion API (CloudConvert-like)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "fontverter": "^2.0.0",
    "jszip": "^3.10.1",
    "mongoose": "^9.7.3",
    "multer": "^2.0.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.33.4"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
