# ---- build aşaması ----
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

# ---- çalışma aşaması ----
FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=6000
COPY package*.json ./
RUN npm ci --omit=dev && npm cache clean --force
COPY --from=build /app/dist ./dist
EXPOSE 6000
CMD ["node", "dist/index.js"]
