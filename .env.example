# =========================================================================
# Toolbox — production environment
# Copy this file to ".env" and fill in the values, then:
#   docker compose -f docker-compose.prod.yml up -d --build
# TLS is terminated by your host nginx (see deploy/nginx-host.conf.example).
# =========================================================================

# ---- Public domain (used for the CORS origin) ----
DOMAIN=toolbox.fatihakyol.com

# ---- Shared MongoDB (one mongo server for every project on this host) ----
# The database runs as the "shared-mongo" container on the external "shared"
# Docker network. This project has its own database + DB user inside it.
# Create the user once (as the mongo admin):
#   docker exec shared-mongo mongosh -u admin -p '<admin-pw>' --authenticationDatabase admin --eval \
#     'db.getSiblingDB("toolbox").createUser({user:"toolbox",pwd:"<db-pw>",roles:[{role:"readWrite",db:"toolbox"}]})'
MONGO_URI=mongodb://toolbox:<db-pw>@shared-mongo:27017/toolbox?authSource=toolbox

# ---- Security secrets (REQUIRED — generate long random values) ----
# Tip: generate each with  ->  openssl rand -hex 32
SESSION_SECRET=
SECRET_ENCRYPTION_KEY=

# ---- First admin account (seeded on first startup if no admin exists) ----
# You must change this password on first login.
ADMIN_EMAIL=admin@fatihakyol.com
ADMIN_PASSWORD=

# ---- File transfer limits (optional — sensible defaults shown) ----
# Max total upload size per transfer, in bytes (2 GB).
MAX_TRANSFER_SIZE=2147483648
# Max number of files per transfer.
MAX_TRANSFER_FILES=20
